    {
      "parameters": {
        "jsCode": "// NORMALIZADOR UNIVERSAL DE CANALES\n// Unifica el formato sin importar el canal de entrada\nconst body = $json.body || $json;\nconst headers = $json.headers || {};\n\nlet canal = 'desconocido';\nlet telefono = '';\nlet nombre = 'Visitante';\nlet mensaje = '';\nlet idMensaje = '';\nlet tipoMensaje = 'text';\nlet audioId = '';\nlet imageCaption = '';\nlet numeroNegocio = '';\n\n// ---- WHATSAPP (YCloud) ----\nif (body.whatsappInboundMessage) {\n  const wa = body.whatsappInboundMessage;\n  canal          = 'whatsapp';\n  telefono       = wa.from || '';\n  nombre         = wa.customerProfile?.name || 'Sin nombre';\n  mensaje        = wa.text?.body || '';\n  idMensaje      = wa.wamid || wa.id || '';\n  tipoMensaje    = wa.type || 'text';\n  audioId        = wa.audio?.id || '';\n  imageCaption   = wa.image?.caption || '';\n  numeroNegocio  = wa.to || '';\n}\n\n// ---- MESSENGER (Meta) ----\nelse if (body.object === 'page' || body.entry) {\n  canal = 'messenger';\n  try {\n    const entry    = body.entry?.[0];\n    const msgEvent = entry?.messaging?.[0];\n    telefono       = msgEvent?.sender?.id || '';\n    nombre         = 'Usuario Messenger';\n    mensaje        = msgEvent?.message?.text || '';\n    idMensaje      = msgEvent?.message?.mid || '';\n    numeroNegocio  = msgEvent?.recipient?.id || '';\n  } catch(e) {}\n}\n\n// ---- WEBCHAT ----\nelse if (body.canal === 'webchat' || body.source === 'webchat') {\n  canal         = 'webchat';\n  telefono      = body.session_id || body.userId || '';\n  nombre        = body.nombre || body.name || 'Visitante Web';\n  mensaje       = body.mensaje || body.message || body.text || '';\n  idMensaje     = body.msg_id || Date.now().toString();\n  numeroNegocio = 'webchat';\n}\n\n// ---- FORMULARIO ----\nelse if (body.canal === 'formulario' || body.source === 'form') {\n  canal         = 'formulario';\n  telefono      = body.telefono || body.phone || body.whatsapp || '';\n  nombre        = body.nombre || body.name || '';\n  mensaje       = body.mensaje || body.consulta || body.message || '';\n  idMensaje     = body.form_id || Date.now().toString();\n  numeroNegocio = 'formulario';\n}\n\nreturn [{ json: {\n  canal,\n  Telefono:      telefono,\n  Nombre:        nombre,\n  Mensaje:       mensaje,\n  IDMensaje:     idMensaje,\n  TipoMensaje:   tipoMensaje,\n  audioId,\n  imageCaption,\n  NumeroNegocio: numeroNegocio,\n  timestamp:     new Date().toISOString()\n} }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [52640, 20336],
      "id": "code-norm-001",
      "name": "Normalizar Canal"
    },
