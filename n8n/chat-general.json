                "conditions": [{ "id": "sw-int-cot", "leftValue": "={{ $json.intencion }}", "rightValue": "solicitud_cotizacion", "operator": { "type": "string", "operation": "equals" } }],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "cotizacion"
            }
          ]
        },
        "options": { "fallbackOutput": "extra", "renameFallbackOutput": "general" }
