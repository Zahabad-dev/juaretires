        "jsCode": "// Agrega el inventario al contexto del Agente IA\nconst datos = $input.all();\nconst inventario = datos.map(item => {\n  const r = item.json;\n  return `${r.Producto || r.producto || '—'} | Medida: ${r.Medida || r.medida || '—'} | Stock: ${r.Stock || r.stock || '0'} | Precio: ${r.Precio || r.precio || '—'}`;\n}).join('\\n');\n\nconst base = $('Clasificar Intención').first().json;\nreturn [{ json: { \n  ...base,\n  contexto_stock: `INVENTARIO ACTUAL:\\n${inventario}`,\n  intencion: 'consulta_stock'\n} }];"
      },
