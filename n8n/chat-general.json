    {
      "parameters": {
        "jsCode": "// CLASIFICADOR DE INTENCIÓN — sin llamada extra a OpenAI\n// Devuelve: 'consulta_stock' | 'solicitud_cotizacion' | 'general'\nconst msg = (($json.Mensaje || $json.text || '').toLowerCase());\n\nconst STOCK_KEYWORDS = [\n  'tienen', 'hay', 'stock', 'disponible', 'existe', 'manejan',\n  'llanta', 'llantas', 'rin', 'rines', 'medida', 'medidas',\n  '175', '185', '195', '205', '215', '225', '235', '245', '255',\n  'r13', 'r14', 'r15', 'r16', 'r17', 'r18', 'r19', 'r20',\n  'seminueva', 'nueva', 'usada'\n];\n\nconst COTIZACION_KEYWORDS = [\n  'cotiz', 'precio', 'cuanto', 'cuánto', 'cuesta', 'valen', 'vale',\n  'cuánto sale', 'cuanto sale', 'presupuesto', 'cotizacion', 'cotización'\n];\n\nlet intencion = 'general';\n\nif (COTIZACION_KEYWORDS.some(k => msg.includes(k))) {\n  intencion = 'solicitud_cotizacion';\n} else if (STOCK_KEYWORDS.some(k => msg.includes(k))) {\n  intencion = 'consulta_stock';\n}\n\nreturn [{ json: { ...$json, intencion } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [53800, 20336],
      "id": "code-intent-001",
      "name": "Clasificar Intención"
    },

