# Copia como .env.local para desarrollo.
# En Vercel: agregar las mismas variables en Settings → Environment Variables.
# En Easypanel: agregar en la sección Env Vars del servicio.
# NUNCA subir .env.local al repositorio.

# --- Sitio público ---
# Número de WhatsApp de Juare Tires (formato internacional sin "+", ej. 521XXXXXXXXXX)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Base de datos (solo backend) ---
# Cadena de conexión PostgreSQL con usuario de SOLO LECTURA
# Formato: postgresql://crm_readonly:PASSWORD@HOST:5432/juare_tires
DATABASE_URL=

# --- Autenticación CRM (NextAuth / Auth.js v5) ---
# URL base del sitio (https://juare-tires.vercel.app o http://IP:PUERTO en Easypanel)
NEXTAUTH_URL=
# Secreto para firmar sesiones — generar con: openssl rand -base64 32
AUTH_SECRET=
